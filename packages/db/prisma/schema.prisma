generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  DIGITAL_WALLET
}

enum AccountProvider {
  MERCADOPAGO
  PAYPAL
  WISE
  BRUBANK
  BBVA
  GALICIA
  MANUAL
}

enum TransactionSource {
  API
  EMAIL
  CSV
  MANUAL
}

enum BudgetPeriod {
  MONTHLY
  WEEKLY
}

enum EmailIngestStatus {
  PENDING
  PARSED
  FAILED
  DUPLICATE
}

enum MessageRole {
  user
  assistant
}

enum NotificationType {
  BUDGET_WARNING
  BUDGET_OVER
  UNCATEGORIZED_REMINDER
  SHARED_EXPENSE
  GENERAL
}

enum SharedStatus {
  PENDING
  PARTIALLY_PAID
  SETTLED
}

// ── User ──────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  accounts      Account[]
  transactions  Transaction[]
  budgets       Budget[]
  conversations Conversation[]
  notifications Notification[]
  emailIngests  EmailIngest[]
  settings      UserSettings[]
}

// ── Account ───────────────────────────────────────────────────────────────────
// Multi-tenant ready: filtrar siempre por userId en queries

model Account {
  id           String          @id @default(cuid())
  userId       String          @default("default-user")
  user         User            @relation(fields: [userId], references: [id])
  name         String
  type         AccountType
  currency     String          @default("ARS")
  balance      Decimal         @default(0) @db.Decimal(15, 2)
  provider     AccountProvider
  createdAt    DateTime        @default(now())
  transactions Transaction[]
}

// ── Transaction ───────────────────────────────────────────────────────────────
// Multi-tenant ready: filtrar siempre por userId en queries

model Transaction {
  id                 String            @id @default(cuid())
  userId             String            @default("default-user")
  user               User              @relation(fields: [userId], references: [id])
  accountId          String
  account            Account           @relation(fields: [accountId], references: [id])
  amount             Decimal           @db.Decimal(15, 2)
  currency           String            @default("ARS")
  description        String?
  category           String?
  merchant           String?
  merchantNormalized String?
  date               DateTime
  source             TransactionSource @default(MANUAL)
  rawData            Json?
  isDuplicate        Boolean           @default(false)
  isShared           Boolean           @default(false)
  sharedWith         Int?
  sharedStatus       SharedStatus      @default(SETTLED)
  yourShare          Decimal?          @db.Decimal(15, 2)
  createdAt          DateTime          @default(now())
  emailIngest        EmailIngest[]
}

// ── Budget ────────────────────────────────────────────────────────────────────
// Multi-tenant ready: filtrar siempre por userId en queries

model Budget {
  id               String           @id @default(cuid())
  userId           String           @default("default-user")
  user             User             @relation(fields: [userId], references: [id])
  name             String
  totalAmount      Decimal          @db.Decimal(15, 2)
  period           BudgetPeriod
  startDate        DateTime
  categories       Json             @default("[]")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  budgetCategories BudgetCategory[]
}

model BudgetCategory {
  id              String  @id @default(cuid())
  budgetId        String
  budget          Budget  @relation(fields: [budgetId], references: [id])
  name            String
  allocatedAmount Decimal @db.Decimal(15, 2)
  spentAmount     Decimal @default(0) @db.Decimal(15, 2)
}

// ── EmailIngest ───────────────────────────────────────────────────────────────
// Multi-tenant ready: filtrar siempre por userId en queries

model EmailIngest {
  id            String            @id @default(cuid())
  userId        String            @default("default-user")
  user          User              @relation(fields: [userId], references: [id])
  from          String
  subject       String
  messageId     String?           @unique
  receivedAt    DateTime
  parsedAt      DateTime?
  transactionId String?
  transaction   Transaction?      @relation(fields: [transactionId], references: [id])
  rawBody       String
  status        EmailIngestStatus @default(PENDING)
  createdAt     DateTime          @default(now())
}

// ── UserSettings ──────────────────────────────────────────────────────────────

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @default("default-user")
  user                  User     @relation(fields: [userId], references: [id])
  monthlyIncomeAvg      Decimal? @db.Decimal(15, 2)
  savingsGoalPercent    Float?
  maxInstallmentPercent Float?
  sonnetCallsThisMonth  Int      @default(0)
  sonnetCallsLimit      Int      @default(20)
  haikusCallsThisMonth  Int      @default(0)
  sonnetResetMonth      Int?
  updatedAt             DateTime @updatedAt
}

// ── Conversation ──────────────────────────────────────────────────────────────
// Multi-tenant ready: filtrar siempre por userId en queries

model Conversation {
  id        String    @id @default(cuid())
  userId    String    @default("default-user")
  user      User      @relation(fields: [userId], references: [id])
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           MessageRole
  content        String
  modelUsed      String?
  budgetData     Json?
  createdAt      DateTime     @default(now())
}

// ── Notification ──────────────────────────────────────────────────────────────
// Multi-tenant ready: filtrar siempre por userId en queries

model Notification {
  id        String           @id @default(cuid())
  userId    String           @default("default-user")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}
