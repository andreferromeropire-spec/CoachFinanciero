DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coach_financiero"
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
PUBLIC_WEB_URL="http://localhost:3000"

# Resend (mails: recuperar contraseña)
# - Sin RESEND_API_KEY el API no llama a Resend (revisá logs o poné la key en Railway).
# - RESEND_FROM: debe coincidir con un email de un dominio verificado en resend.com (mismo servicio de Railway
#   donde corre el API). Si queda "onboarding@resend.dev", Resend 403 a cualquier correo que no sea el de la cuenta.
#   Ej: RESEND_FROM="App <notificaciones@tudominio.com>"
# - PUBLIC_WEB_URL: URL pública de la app (build del web); si queda en localhost, el enlace del mail apunta mal.
RESEND_API_KEY=
RESEND_FROM="Coach <notificaciones@tudominio.com>"

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_COLLECTOR_ID=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=true

# Wise
WISE_API_TOKEN=
WISE_WEBHOOK_PUBLIC_KEY=

# IMAP para importación de historial de mails
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=         # tu casilla@gmail.com
IMAP_PASSWORD=     # App Password de Gmail (no tu contraseña normal)

# Usuario admin (se crea automáticamente con prisma db seed)
ADMIN_EMAIL=admin@coachfinanciero.local
ADMIN_PASSWORD=    # Mínimo 12 caracteres
ADMIN_NAME=Admin

# Dominio para el email de ingest por usuario
INGEST_EMAIL_DOMAIN=ingest.coachfinanciero.app
